CIPHER = (("D", "A", "V", "I", "O"),
          ("Y", "N", "E", "R", "B"),
          ("C", "F", "G", "H", "K"),
          ("L", "M", "P", "Q", "S"),
          ("T", "U", "W", "X", "Z"))



#Add your code here!
def find_letter(letter):
    for row in range(5):
        for column in range(5):
            if CIPHER[row][column] == letter:
                return row, column

def encrypt(astring):
    encrypt = astring
    newstring = ""
    encrypt = encrypt.upper()
    for letter in encrypt:
        if letter not in ".,;:'\"[]{}-+=!@#$%^&*()1234567890`~ ":
            if letter == "J":
                newstring += "I"
            else:
                newstring += letter
    if len(newstring) % 2 == 1:
        newstring += "X"
    result = ""
    for i in range(0, len(newstring), 2):
        pair = newstring[i] + newstring[i+1]
        if pair[0] == pair[1]:
            pair = pair[0] + "X"
        row1, col1 = find_letter(pair[0])
        row2, col2 = find_letter(pair[1])
        if row1 != row2 and col1 != col2:
            new_letter1 = CIPHER[row1][col2]
            new_letter2 = CIPHER[row2][col1]
        if row1 == row2 and col1 != col2:
            new_letter1 = CIPHER[row1][(col1 + 1) % 5]
            new_letter2 = CIPHER[row2][(col2 + 1) % 5]
        if row1 != row2 and col1 == col2:
            new_letter1 = CIPHER[(row1 + 1) % 5][col1]
            new_letter2 = CIPHER[(row2 + 1) % 5][col2]
        result += new_letter1 + new_letter2
    
    return result

def decrypt(astring):
    encrypt = astring
    newstring = ""
    encrypt = encrypt.upper()
    for letter in encrypt:
        if letter not in ".,;:'\"[]{}-+=!@#$%^&*()1234567890`~ ":
            if letter == "J":
                newstring += "I"
            else:
                newstring += letter
    if len(newstring) % 2 == 1:
        newstring += "X"
    result = ""
    for i in range(0, len(newstring), 2):
        pair = newstring[i] + newstring[i+1]
        if pair[0] == pair[1]:
            pair = pair[0] + "X"
        row1, col1 = find_letter(pair[0])
        row2, col2 = find_letter(pair[1])
        if row1 != row2 and col1 != col2:
            new_letter1 = CIPHER[row1][col2]
            new_letter2 = CIPHER[row2][col1]
        if row1 == row2 and col1 != col2:
            new_letter1 = CIPHER[row1][(col1 - 1) % 5]
            new_letter2 = CIPHER[row2][(col2 - 1) % 5]
        if row1 != row2 and col1 == col2:
            new_letter1 = CIPHER[(row1 - 1) % 5][col1]
            new_letter2 = CIPHER[(row2 - 1) % 5][col2]
        result += new_letter1 + new_letter2
    
    return result



