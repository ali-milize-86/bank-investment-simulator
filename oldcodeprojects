#Add your class here!
class Stack:
    def __init__(self):
        self.stack = []
    def stack_push(self, anitem):
        self.stack.append(anitem)
    def stack_pop(self):
        if len(self.stack) == 0:
            return None
        top = self.stack[-1]        # get the last item
        self.stack = self.stack[:-1] # remove the last item
        return top 
        
    
        


