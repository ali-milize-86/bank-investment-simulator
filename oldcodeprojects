#   Python "wraps around" and checks the last value. You
#   may have to control for this.


#Write your function here!

def check_winner(a2dlist):
    # check horizontal
    for row in a2dlist:
        for col in range(len(row) - 3):  # stop 3 from end
            if row[col] == row[col+1] == row[col+2] == row[col+3] and row[col] is not None:
                return row[col]
    # check vertical
    for col in range(len(a2dlist[0])):
        for row in range(len(a2dlist) - 3):
            if a2dlist[row][col] == a2dlist[row+1][col] == a2dlist[row+2][col] == a2dlist[row+3][col] and a2dlist[row][col] is not None:
                return a2dlist[row][col]
    # check diagonal top-left to bottom-right
    for row in range(len(a2dlist) - 3):
        for col in range(len(a2dlist[0]) - 3):
            if a2dlist[row][col] == a2dlist[row+1][col+1] == a2dlist[row+2][col+2] == a2dlist[row+3][col+3] and a2dlist[row][col] is not None:
                return a2dlist[row][col]
    # check diagonal bottom-left to top-right
    for row in range(3, len(a2dlist)):
        for col in range(len(a2dlist[0]) - 3):
            if a2dlist[row][col] == a2dlist[row-1][col+1] == a2dlist[row-2][col+2] == a2dlist[row-3][col+3] and a2dlist[row][col] is not None:
                return a2dlist[row][col]
    return None


